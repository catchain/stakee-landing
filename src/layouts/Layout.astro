    function setLang(lang) {
      document.documentElement.setAttribute('data-lang', lang);
      document.documentElement.setAttribute('lang', lang);
      localStorage.setItem('stakee-lang', lang);

      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (translations[lang] && translations[lang][key]) {
          el.textContent = translations[lang][key];
        }
      });

      const toggle = document.getElementById('lang-toggle');
      if (toggle) {
        toggle.textContent = lang === 'en' ? 'RU' : 'EN';
        toggle.setAttribute('aria-label', lang === 'en' ? 'Switch to Russian' : 'Switch to English');
      }

      // Re-run calculator with new lang suffix
      const calcDays = document.getElementById('calc-days');
      if (calcDays) {
        calcDays.dispatchEvent(new Event('input'));
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const saved = localStorage.getItem('stakee-lang') || 'en';
      setLang(saved);

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-lang') || 'en';
        setLang(current === 'en' ? 'ru' : 'en');
      });
    });
  </script>
</body>
</html>
