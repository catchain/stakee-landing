---
---

<section class="cta-banner-section">
  <div class="container">
    <div class="cta-banner">
      <div class="cta-banner-content">
        <h3 class="cta-banner-title" data-i18n="cta.title">Exclusive Custom Terms</h3>
        <p class="cta-banner-subtitle" data-i18n="cta.subtitle">Special Terms for Large Clients and Businesses</p>
      </div>
      <div class="cta-banner-decor" aria-hidden="true">
        <svg viewBox="0 0 320 140" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="150" y="15" width="35" height="35" rx="4" transform="rotate(20 167 32)" fill="rgba(255,255,255,0.18)" />
          <circle cx="260" cy="35" r="22" fill="rgba(255,255,255,0.22)" />
          <rect x="190" y="80" width="28" height="28" rx="14" transform="rotate(-15 204 94)" fill="rgba(255,255,255,0.14)" />
          <rect x="280" y="70" width="30" height="30" rx="4" transform="rotate(35 295 85)" fill="rgba(255,255,255,0.2)" />
          <circle cx="160" cy="100" r="16" fill="rgba(255,255,255,0.12)" />
          <rect x="230" y="95" width="20" height="20" rx="10" fill="rgba(255,255,255,0.16)" />
          <rect x="130" y="55" width="18" height="18" rx="2" transform="rotate(45 139 64)" fill="rgba(255,255,255,0.1)" />
        </svg>
      </div>
      <a href="https://t.me/stakee?direct" class="cta-banner-btn" data-i18n="cta.btn" data-i18n-href="cta.href">Get offer</a>
    </div>
  </div>
</section>

<style>
  .cta-banner-section {
    padding: 32px 0 0;
    margin-bottom: -24px;
  }

  .cta-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(135deg, #1565C0 0%, #1C8DFF 50%, #3BB9FE 100%);
    border-radius: var(--radius-xl);
    padding: 36px 40px;
    overflow: hidden;
    min-height: 120px;
  }

  .cta-banner-content {
    position: relative;
    z-index: 2;
    flex: 1;
  }

  .cta-banner-title {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .cta-banner-subtitle {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 400;
  }

  .cta-banner-decor {
    position: absolute;
    right: 80px;
    top: 0;
    bottom: 0;
    width: 320px;
    z-index: 1;
    pointer-events: none;
  }

  .cta-banner-decor svg {
    width: 100%;
    height: 100%;
  }

  .cta-banner-btn {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fff;
    color: #1A1D26;
    font-size: 15px;
    font-weight: 600;
    padding: 12px 28px;
    border-radius: var(--radius-full);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    flex-shrink: 0;
  }

  .cta-banner-btn:hover {
    opacity: 0.92;
  }

  @media (max-width: 768px) {
    .cta-banner-section {
      padding-top: 24px;
      margin-bottom: -16px;
    }

    .cta-banner {
      padding: 28px 24px;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .cta-banner-title {
      font-size: 22px;
    }

    .cta-banner-decor {
      right: 0;
      opacity: 0.5;
    }
  }

  @media (max-width: 480px) {
    .cta-banner {
      padding: 24px 20px;
    }

    .cta-banner-title {
      font-size: 20px;
    }

    .cta-banner-subtitle {
      font-size: 14px;
    }

    .cta-banner-btn {
      font-size: 14px;
      padding: 10px 24px;
    }
  }
</style>
