---
---

<section class="hero">
  <div class="hero-glow"></div>
  <div class="container hero-inner">
    <h1 class="hero-title">
      <span data-i18n="hero.title">Put your TON to work</span><br/>
      <span class="text-gradient" data-i18n="hero.title2">Earn up to 25% APY</span>
    </h1>
    <p class="hero-subtitle" data-i18n="hero.subtitle">
      The most secure staking contract on TON with instant withdrawals. Manage everything right in Telegram.
    </p>
    <div class="hero-actions">
      <a href="https://t.me/StakeeBot?start=landing" class="btn btn-primary">
        <img src="/ton.svg" alt="" class="hero-cta-icon" width="22" height="22" />
        <span data-i18n="hero.cta">Stake in Telegram</span>
      </a>
      <a href="https://app.stakee.org" class="btn btn-secondary">
        <span data-i18n="hero.ctaSecondary">Continue on site ›</span>
      </a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-value" id="hero-apy">21%</span>
        <span class="hero-stat-label" data-i18n="hero.stat.apy">Annual Yield</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-value" id="hero-tvl">$25 M</span>
        <span class="hero-stat-label" data-i18n="hero.stat.tvl">Total Value Locked</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-value" id="hero-stakers">14 000</span>
        <span class="hero-stat-label" data-i18n="hero.stat.stakers">Stakers</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    window.loadStakeeData().then(function(data) {
      if (!data) return;

      var apyEl = document.getElementById('hero-apy');
      var tvlEl = document.getElementById('hero-tvl');
      var stakersEl = document.getElementById('hero-stakers');

      if (apyEl) apyEl.textContent = window.fmtApy(data.apy);
      if (tvlEl) tvlEl.textContent = window.fmtTvlUsd(data.tvlTon, data.tonUsd);
      if (stakersEl) stakersEl.textContent = window.fmtNum(data.totalStakers);
    });
  });
</script>

<style>
  :global(.page-top) {
    position: relative;
  }

  .hero {
    position: relative;
    padding: 112px 0 100px;
    overflow: hidden;
    text-align: center;
  }

  .hero-glow {
    position: absolute;
    top: -280px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(28, 141, 255, 0.08) 0%, rgba(59, 185, 254, 0.04) 40%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: 56px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
  }

  .hero-subtitle {
    font-size: 20px;
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-actions .btn {
    padding: 16px 40px;
    font-size: 18px;
  }

  .hero-actions .btn-secondary {
    padding: 16px 24px;
    font-size: 15px;
    font-weight: 500;
    background: transparent;
    color: var(--color-text-secondary);
    border: none;
    box-shadow: none;
  }

  .hero-actions .btn-secondary:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.04);
  }

  .hero-cta-icon {
    flex-shrink: 0;
    display: block;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 80px;
    margin-top: 48px;
    padding: 24px 36px;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .hero-stat-value {
    font-size: 40px;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -1px;
    line-height: 1;
  }

  .hero-stat-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 96px 0 64px;
    }

    .hero-title {
      font-size: 36px;
      letter-spacing: -0.8px;
    }

    .hero-subtitle {
      font-size: 17px;
    }

    .hero-actions .btn {
      padding: 14px 32px;
      font-size: 16px;
    }

    .hero-actions .btn-secondary {
      padding: 14px 20px;
      font-size: 14px;
    }

    .hero-stats {
      gap: 32px;
      padding: 20px 24px;
      margin-top: 36px;
    }

    .hero-stat-value {
      font-size: 22px;
    }

    .hero-stat-label {
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 30px;
    }

    .hero-subtitle {
      font-size: 16px;
    }

    .hero-stats {
      gap: 24px;
      padding: 16px 16px;
    }

    .hero-stat-label {
      font-size: 10px;
      letter-spacing: 0.3px;
    }
  }
</style>
