---
---

<section id="how-it-works" class="section section-alt">
  <div class="container">
    <div class="how-header">
      <h2 class="section-title" data-i18n="how.title">How It Works</h2>
      <p class="section-subtitle" data-i18n="how.subtitle">Start earning in 3 simple steps</p>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-marker">
          <div class="step-number">1</div>
          <div class="step-line" aria-hidden="true"></div>
        </div>
        <div class="step-content">
          <h3>
            <span data-i18n="how.step1.title.prefix">Open</span>
            <a href="https://t.me/StakeeBot" class="step-bot-link">
              <span data-i18n="how.step1.title.link">Stakee Bot</span>
              <svg class="step-bot-arrow" viewBox="0 0 100 100" aria-hidden="true">
                <path d="M5.965 93.109a6.5 6.5 0 0 0 4.608 1.831 6.5 6.5 0 0 0 4.554-1.961L81.975 26.13v48.516a6.483 6.483 0 1 0 12.962 0V10.483a6.48 6.48 0 0 0-6.48-6.48H24.292a6.482 6.482 0 1 0 0 12.96h48.516L5.96 83.814a6.48 6.48 0 0 0 .005 9.296" fill="currentColor"/>
              </svg>
            </a>
          </h3>
          <p data-i18n="how.step1.desc">Launch our Telegram bot or connect your TON wallet on the web.</p>
        </div>
      </div>
      <div class="step-connector" aria-hidden="true"></div>
      <div class="step">
        <div class="step-marker">
          <div class="step-number">2</div>
          <div class="step-line" aria-hidden="true"></div>
        </div>
        <div class="step-content">
          <h3 data-i18n="how.step2.title">Deposit TON</h3>
          <p data-i18n="how.step2.desc">Enter the amount you want to stake and confirm the deposit in your wallet.</p>
        </div>
      </div>
      <div class="step-connector" aria-hidden="true"></div>
      <div class="step">
        <div class="step-marker">
          <div class="step-number">3</div>
        </div>
        <div class="step-content">
          <h3 data-i18n="how.step3.title">Earn Rewards</h3>
          <p data-i18n="how.step3.desc">Rewards accrue daily with automatic compounding. Withdraw anytime.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .how-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .how-header .section-subtitle {
    margin: 0 auto;
  }

  .steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    max-width: 900px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    padding: 0 16px;
  }

  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .step-line {
    display: none;
  }

  .step-number {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    border-radius: 50%;
    margin-bottom: 20px;
    box-shadow: 0 4px 14px rgba(28, 141, 255, 0.25);
  }

  .step-content h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--color-text);
  }

  .step-bot-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .step-bot-link:hover {
    opacity: 0.8;
  }

  .step-bot-arrow {
    width: 0.7em;
    height: 0.7em;
    flex-shrink: 0;
    opacity: 0.45;
  }

  .step-content p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .step-connector {
    display: none;
  }

  @media (max-width: 768px) {
    .how-header {
      margin-bottom: 40px;
    }

    .steps {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      max-width: none;
    }

    .step {
      display: grid;
      grid-template-columns: 48px 1fr;
      align-items: start;
      text-align: left;
      width: 100%;
      padding: 0;
      column-gap: 16px;
    }

    .step:last-child {
      padding-bottom: 0;
    }

    .step-marker {
      display: flex;
      flex-direction: column;
      align-items: center;
      align-self: stretch;
      grid-row: 1 / -1;
    }

    .step-line {
      display: block;
      width: 2px;
      flex: 1;
      margin: 8px 0;
      background: linear-gradient(180deg, var(--color-primary), var(--color-primary-light));
      opacity: 0.3;
      border-radius: 1px;
    }

    .step-number {
      width: 48px;
      height: 48px;
      font-size: 20px;
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .step-content {
      flex: 1;
      min-width: 0;
      padding-top: 2px;
      padding-bottom: 12px;
    }

    .step-content h3 {
      font-size: 17px;
    }

    .step-content p {
      font-size: 14px;
    }
  }
</style>
